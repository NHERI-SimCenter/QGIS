{
  "vcpkg-configuration": {
    "default-registry": {
      "kind": "git",
      "baseline": "5d57f5a0a5469a23e005fc79a7c1814ab4fc967e",
      "repository": "https://github.com/microsoft/vcpkg"
    },
    "registries": [
      {
        "kind": "git",
        "baseline": "a3f181f299a54a0d67e6e60cac746ea265adfb29",
        "repository": "https://github.com/open-vcpkg/python-registry",
        "packages": [
          "arrow",
          "python3",
          "py-*",
          "gdal",
          "vcpkg-python-scripts",
          "vcpkg-tool-mercurial",
          "vcpkg-tool-rust",
          "pybind11"
        ]
      }
    ],
    "overlay-ports": [
      "ports"
    ],
    "overlay-triplets": [
      "triplets"
    ]
  },
  "name": "qgis",
  "version-string": "current",
  "description": "QGIS is a free, open source, cross platform (lin/win/mac) geographical information system (GIS)",
  "homepage": "https://qgis.org",
  "dependencies": [
    "expat",
    {
      "name": "gdal",
      "default-features": false,
      "features": [
        "freexl"
      ]
    },
    "geos",
    "gsl",
    "jhasse-poly2tri",
    "libspatialindex",
    {
      "name": "libtasn1",
      "platform": "ios | osx"
    },
    "libxml2",
    "libzip",
    "meshoptimizer",
    "nlohmann-json",
    "o2",
    "proj",
    "protobuf",
     "zlib",
    "zstd"
  ],
  "default-features": [
    "recommended-features"
  ],
  "features": {
     "auth": {
      "description": "Build with Auth (QCA) support",
      "dependencies": [
      ]
    },
    "recommended-features": {
      "description": "Enable a recommended QGIS build",
      "dependencies": [
        "duckdb",
        "libpq",
        "libspatialite",
        {
          "name": "gdal",
          "default-features": true,
          "features": [
            "arrow-adbc",
            "kea",
            "parquet",
            "poppler",
            "tools"
          ]
        },
        "opencl"
      ]
    },
    "exiv2": {
      "description": "Determines whether EXIV2 should be built",
      "dependencies": [
        {
          "name": "exiv2",
          "features": [
            "xmp"
          ]
        }
      ]
    },
    "gui": {
      "description": "Determines whether QGIS gui should be built",
      "dependencies": [
      ]
    },
    "opencl": {
      "description": "Should OpenCL support be added",
      "dependencies": [
        "opencl"
      ]
    },
    "oracle": {
      "description": "Build with oracle support",
      "dependencies": [
        "oracle-instantclient"
      ]
    },
    "pdal": {
      "description": "Build with PDAL support",
      "dependencies": [
        "pdal"
      ]
    },
    "proj-data": {
      "description": "Build with proj data",
      "dependencies": [
        "proj-data"
      ]
    },
    "server": {
      "description": "Determines whether QGIS server should be built",
      "dependencies": [
        "fastcgi"
      ]
    },
    "sfcgal": {
      "description": "Build with SFCGAL support",
      "dependencies": [
        "sfcgal"
      ]
    }
  }
}
